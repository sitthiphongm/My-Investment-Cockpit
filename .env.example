# ═══════════════════════════════════════════════════════════════════════════════
# My Investment Cockpit — Environment Variables
# Copy this file to .env and fill in values
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=your-random-secret-key-here

# ─── OAuth — Google (https://console.cloud.google.com/) ───────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OAuth — Facebook (https://developers.facebook.com/) ──────────────────────
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ─── OAuth/App URLs ───────────────────────────────────────────────────────────
OAUTH_REDIRECT_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost
VITE_API_BASE_URL=http://localhost:8000

# ─── Market Data Providers ────────────────────────────────────────────────────
# Options: fmp, alpha_vantage, twelve_data, eodhd, yfinance
MARKET_DATA_PROVIDER=yfinance
MARKET_DATA_FALLBACK=yfinance
FMP_API_KEY=
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=
EODHD_API_KEY=

# ─── FX Rates ────────────────────────────────────────────────────────────────
# Options: unirate, alpha_vantage, manual
FX_PROVIDER=manual
FX_API_KEY=
FX_CACHE_TTL_HOURS=24

# ─── Cache TTL (seconds) ─────────────────────────────────────────────────────
MARKET_DATA_CACHE_TTL=3600
TRENDING_CACHE_TTL=900

# ─── Provider Resilience ─────────────────────────────────────────────────────
PROVIDER_CIRCUIT_BREAKER_THRESHOLD=5
PROVIDER_CIRCUIT_BREAKER_TIMEOUT=300
PROVIDER_RATE_LIMIT_PER_MINUTE=30

# ─── Email Notifications ─────────────────────────────────────────────────────
# Options: smtp, sendgrid, mailgun, ses
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SENDGRID_API_KEY=
ALERT_EMAIL_ENABLED=false
EMAIL_DEV_MODE=true

# ─── AI Insights ─────────────────────────────────────────────────────────────
# Options: disabled, rule_based, local_llm, hosted_llm
AI_PROVIDER=disabled
AI_LOCAL_MODEL_PATH=
AI_HOSTED_API_KEY=
AI_HOSTED_ENDPOINT=
